# Required environment variables
# Local dev: copy this file to .env and fill in values.
# CI/CD: these are stored as GitHub secrets and written to /volume1/docker/claude-fitbit/.env on each deploy.

# Fitbit OAuth2 app credentials (create at dev.fitbit.com)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Default user key for single-user setups (matches key in tokens.json)
FITBIT_DEFAULT_USER=charles

# Server config
SERVER_HOST=0.0.0.0
PORT=8770

# brian-mem integration (optional — omit to skip memory writes)
BRIAN_MEM_URL=
BRIAN_MEM_USER=
BRIAN_MEM_PASS=
